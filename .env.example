# =============================================================================
# Watheeq AI Service — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# === LLM Configuration ===
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# === Firebase (Optional — Mode A) ===
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=watheeq-ai
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# === Service Configuration ===
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://watheeq.ai
API_VERSION=v1
BEARER_TOKEN=your-secret-token

# === Processing ===
MAX_PDF_SIZE_MB=20
ANALYSIS_TIMEOUT_SECONDS=60
